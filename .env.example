# ============================================================
# Tranquara Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# ⚠️  NEVER commit .env to version control!
#
# LOCAL DEV:  Values below are pre-configured for docker compose.
# AZURE:     See AZURE-DEPLOY.md — env vars are set via
#            `az containerapp create --env-vars` instead.
# ============================================================

# ── Environment ──────────────────────────────────────────────
# development | staging | production
ENVIRONMENT=development

# ── PostgreSQL ───────────────────────────────────────────────
# Local:  Docker container
# Azure:  Azure Database for PostgreSQL Flexible Server
POSTGRES_DB=tranquara_core
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD

# ── Core Service (Go Backend) ───────────────────────────────
# Local:  sslmode=disable (no TLS for local Docker Postgres)
# Azure:  sslmode=require (auto-detected when ENVIRONMENT=production)
TRANQUARA_DB_DSN=postgres://postgres:CHANGE_ME_TO_A_STRONG_PASSWORD@db:5432/tranquara_core?sslmode=disable
RABBITMQ_URL=amqp://rabbitmq:CHANGE_ME_RABBITMQ_PASSWORD@rabbitmq:5672/
INTERNAL_API_KEY=CHANGE_ME_GENERATE_A_RANDOM_KEY

# CORS — comma-separated allowed origins
ALLOWED_ORIGINS=http://localhost:3000

# SMTP (for email notifications)
SMTP_HOST=
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_SENDER=Tranquara <no-reply@yourdomain.com>

# ── AI Service (Python FastAPI) ──────────────────────────────
OPENAI_API_KEY=sk-YOUR_OPENAI_API_KEY_HERE

# RabbitMQ connection (used by AI service)
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=rabbitmq
RABBITMQ_PASSWORD=CHANGE_ME_RABBITMQ_PASSWORD

# ── Qdrant connection ────────────────────────────────────────
# Local:  qdrant (container name)
# Azure:  Qdrant Cloud host (e.g., abc123.us-east4-0.gcp.cloud.qdrant.io)
QDRANT_HOST=qdrant
QDRANT_PORT=6333
# QDRANT_API_KEY=          # Only needed for Qdrant Cloud (production)

# Core service URL (for AI→Core internal calls)
CORE_SERVICE_URL=http://core_service:4000

# Memory generation interval (hours)
MEMORY_INTERVAL_HOURS=12

# ── RabbitMQ ─────────────────────────────────────────────────
# (used by the RabbitMQ container itself)
# RABBITMQ_USER and RABBITMQ_PASSWORD above are reused

# ── Keycloak ─────────────────────────────────────────────────
KC_ADMIN_USERNAME=admin
KC_ADMIN_PASSWORD=CHANGE_ME_KEYCLOAK_ADMIN_PASSWORD

# ── Frontend (Nuxt 3) ───────────────────────────────────────
NUXT_PUBLIC_BASE_URL=http://localhost:4000
NUXT_PUBLIC_BASE_FRONTEND_URL=http://localhost:3000
NUXT_PUBLIC_WEBSOCKET_URL=ws://localhost:4000
NUXT_PUBLIC_KEYCLOAK_URL=http://localhost:4200
NUXT_PUBLIC_KEYCLOAK_REALM=tranquara_auth
NUXT_PUBLIC_KEYCLOAK_CLIENT_ID=tranquara_client
NUXT_PUBLIC_KEYCLOAK_CLIENT_SECRET=

# ── Port Mappings (optional overrides) ───────────────────────
# FRONTEND_PORT=3000
# CORE_PORT=4000
# AI_PORT=8000
# DB_PORT=5432
# RABBITMQ_PORT=5672
# RABBITMQ_MGMT_PORT=15672
# QDRANT_PORT=6333
# KEYCLOAK_PORT=4200
